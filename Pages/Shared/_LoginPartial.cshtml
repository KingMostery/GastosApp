@using Microsoft.AspNetCore.Identity
@using GastosApp.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="user-actions">
        <span class="chip-user">@User.Identity?.Name</span>
        <a class="btn-soft" asp-area="Identity" asp-page="/Account/Manage/Index" title="Administrar">Cuenta</a>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
            <button type="submit" class="btn-danger">Salir</button>
        </form>
    </div>
}
else
{
    <div class="user-actions">
        <a class="btn-soft" asp-area="Identity" asp-page="/Account/Register">Registrarse</a>
        <a class="btn-brand" asp-area="Identity" asp-page="/Account/Login">Iniciar sesion</a>
    </div>
}
