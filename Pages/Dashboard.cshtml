@page
@model GastosApp.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="dashboard-stack">
    <div class="dashboard-header">
        <div>
            <span class="hero-badge">Panel financiero</span>
            <h1 class="page-title mt-3">Hola, @Model.UsuarioActual.NombreCompleto</h1>
            <p class="page-subtitle">Aquí tienes un resumen simple de tu actividad reciente. Para ver todo el historial, entra a Gastos.</p>
        </div>

        <div class="action-row">
            <a asp-page="/Gastos" class="btn-brand">Ir a Gastos</a>
            <a asp-page="/Privacy" class="btn-soft">Ver privacidad</a>
        </div>
    </div>

    <section class="stats-grid">
        <article class="metric-box metric-box-strong mb-0">
            <div class="label">Últimos 30 días</div>
            <div class="value">@Model.TotalUltimos30Dias.ToString("C")</div>
        </article>
        <article class="metric-box mb-0">
            <div class="label">Gastos en 30 días</div>
            <div class="value">@Model.MovimientosUltimos30Dias</div>
        </article>
        <article class="metric-box mb-0">
            <div class="label">Últimos 15 días</div>
            <div class="value">@Model.TotalUltimos15Dias.ToString("C")</div>
        </article>
    </section>

    <section class="dashboard-grid">
        <article class="content-card mb-0">
            <div class="section-head">
                <div>
                    <h2 class="section-title">Movimientos recientes</h2>
                    <p class="section-text">Estos son tus últimos gastos dentro de los últimos 30 días.</p>
                </div>
            </div>

            @if (Model.GastosRecientes.Count == 0)
            {
                <p class="empty-state">No tienes gastos registrados en los últimos 30 días.</p>
            }
            else
            {
                <div class="recent-list">
                    @foreach (var gasto in Model.GastosRecientes)
                    {
                        <div class="recent-item">
                            <div>
                                <strong>@gasto.Categoria.ToDisplayName()</strong>
                                <div class="section-text">@gasto.MetodoPago.ToDisplayName() - @gasto.Fecha.ToString("dd/MM/yyyy")</div>
                                @if (!string.IsNullOrWhiteSpace(gasto.Descripcion))
                                {
                                    <div class="recent-note">@gasto.Descripcion</div>
                                }
                            </div>
                            <div class="category-total">@gasto.Valor.ToString("C")</div>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="content-card mb-0">
            <div class="section-head">
                <div>
                    <h2 class="section-title">Categorías más activas</h2>
                    <p class="section-text">Distribución de tus gastos de los últimos 30 días.</p>
                </div>
            </div>

            @if (Model.ResumenPorCategoria.Count == 0)
            {
                <p class="empty-state">Todavía no hay suficiente información para mostrar categorías.</p>
            }
            else
            {
                <div class="category-list">
                    @foreach (var categoria in Model.ResumenPorCategoria)
                    {
                        <div class="category-row">
                            <div>
                                <strong>@categoria.Categoria.ToDisplayName()</strong>
                                <div class="section-text">@categoria.Cantidad movimiento(s)</div>
                            </div>
                            <div class="category-total">@categoria.Total.ToString("C")</div>
                        </div>
                    }
                </div>
            }
        </article>
    </section>
</section>
