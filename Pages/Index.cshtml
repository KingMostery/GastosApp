@page
@model IndexModel
@{
    ViewData["Title"] = "GastosApp";
}

<section class="home-grid">
    <article class="hero-card">
        <span class="hero-badge">Experiencia bancaria moderna</span>
        <h1 class="hero-title">
            Control total de tus finanzas con
            <span>estilo y claridad</span>
        </h1>
        <p class="hero-text">
            Gestiona ingresos, gastos y metas desde una interfaz limpia, rapida y elegante.
            Pensada para que todo se entienda en segundos y cada accion se sienta simple.
        </p>

        <div class="action-row">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn-brand">Abrir cuenta</a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn-soft">Ya tengo cuenta</a>
        </div>
    </article>

    <aside class="panel-card">
        <div class="panel-header">
            <h2 class="h5 m-0">Resumen mensual</h2>
            <span class="panel-chip">Abril 2026</span>
        </div>

        <div class="metric-box">
            <div class="label">Disponible</div>
            <div class="value">$2.480.000</div>
        </div>

        <div class="metric-grid">
            <div class="metric-box mb-0">
                <div class="label">Ingresos</div>
                <div class="value up">+$3.200.000</div>
            </div>
            <div class="metric-box mb-0">
                <div class="label">Gastos</div>
                <div class="value down">-$720.000</div>
            </div>
        </div>
    </aside>
</section>
