@page
@model GastosApp.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar sesion";
}

<section class="auth-wrap">
    <h1 class="page-title mb-1">Iniciar sesion</h1>
    <p class="page-subtitle mb-4">Accede a tu cuenta de GastosApp.</p>

    <form method="post" class="auth-card">
        <div>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" placeholder="correo@ejemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn-brand w-100">Entrar</button>
        </div>
    </form>

    <p class="mt-3 text-muted">
        No tienes cuenta?
        <a asp-page="/Account/Register" asp-route-returnUrl="@Model.ReturnUrl">Registrate</a>
    </p>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
